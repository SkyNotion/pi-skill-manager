{
  "name": "@skynotion/pi-skill-manager",
  "version": "0.3.0",
  "description": "Skill enable/disable manager for Pi with category toggling, custom skill paths, per-session overrides, bookmarks, tags, and 8 group-by modes",
  "main": "index.ts",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "tui",
    "skills",
    "productivity"
  ],
  "homepage": "https://github.com/SkyNotion/pi-skill-manager#readme",
  "bugs": {
    "url": "https://github.com/SkyNotion/pi-skill-manager/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkyNotion/pi-skill-manager.git"
  },
  "author": "SkyNotion",
  "license": "MIT",
  "files": [
    "index.ts",
    "overlay.ts",
    "scan.ts",
    "state.ts",
    "config.ts",
    "session.ts",
    "categories.ts",
    "source.ts",
    "body.ts",
    "tags.ts",
    "groupings.ts",
    "preview.png",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.1.0",
    "@mariozechner/pi-tui": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": { "optional": false },
    "@mariozechner/pi-tui": { "optional": false }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}